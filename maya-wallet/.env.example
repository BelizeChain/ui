# BelizeChain Maya Wallet - Environment Configuration
# Copy this file to .env.local and configure for your environment

# ============================================================================
# BLOCKCHAIN CONNECTION
# ============================================================================

# BelizeChain node WebSocket endpoint
# Development: ws://127.0.0.1:9944
# Production: wss://testnet.belizechain.org/ws
NEXT_PUBLIC_BLOCKCHAIN_WS=ws://127.0.0.1:9944
NEXT_PUBLIC_BLOCKCHAIN_RPC=http://127.0.0.1:9933

# Network identification
NEXT_PUBLIC_NETWORK_NAME=BelizeChain
NEXT_PUBLIC_CHAIN_ID=belizechain

# ============================================================================
# PYTHON SERVICE ENDPOINTS
# ============================================================================

# Nawal federated learning API
# Handles privacy-preserving ML, PoUW rewards
NEXT_PUBLIC_NAWAL_API=http://localhost:8080

# Kinich quantum computing API
# Handles quantum job submissions, PQW verification
NEXT_PUBLIC_KINICH_API=http://localhost:8888

# Pakit decentralized storage API
# Handles IPFS/Arweave uploads, document proofs
NEXT_PUBLIC_PAKIT_API=http://localhost:8001

# IPFS gateway for stored content
NEXT_PUBLIC_IPFS_GATEWAY=http://localhost:8082/ipfs

# ============================================================================
# GEM SMART CONTRACTS
# ============================================================================

NEXT_PUBLIC_DALLA_CONTRACT=r1SAvDb2f5iFbafWL87rE1jP6QV3qCV5xtK8b1QXuqKpGknj5
NEXT_PUBLIC_BELI_NFT_CONTRACT=r1Wywor1ittVCyZeYaA9hweBwuDiXLC2UdLNQm4oUB1ub8qyN
NEXT_PUBLIC_DAO_CONTRACT=r1VnpeWtfLmtZ2W2UJhYXSLoHhwo7tAY48RZyVirRu5ucLi7i
NEXT_PUBLIC_FAUCET_CONTRACT=r1TDXUdxgeLC5BAkFQeZnZNSAX67FwRAaavmG19TzPtc2Szcg

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable experimental features (quantum computing, advanced staking)
NEXT_PUBLIC_ENABLE_EXPERIMENTAL=false

# Enable development tools (debug logs, performance monitoring)
NEXT_PUBLIC_DEV_MODE=true

# Enable testnet features (faucet, test tokens)
NEXT_PUBLIC_TESTNET_MODE=true

# ============================================================================
# UI CONFIGURATION
# ============================================================================

# Default language (en, es, kr - Belize's official languages)
NEXT_PUBLIC_DEFAULT_LANGUAGE=en

# Enable multi-language support
NEXT_PUBLIC_I18N_ENABLED=true

# Transaction confirmation requirements
NEXT_PUBLIC_CONFIRMATIONS_REQUIRED=1

# ============================================================================
# EXTERNAL INTEGRATIONS (Optional)
# ============================================================================

# Block explorer URL (for transaction links)
# NEXT_PUBLIC_EXPLORER_URL=https://explorer.belizechain.bz

# Analytics tracking (optional)
# NEXT_PUBLIC_ANALYTICS_ID=

# Sentry error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=

# ============================================================================
# SECURITY
# ============================================================================

# Max transaction amount without confirmation (in DALLA)
NEXT_PUBLIC_MAX_AUTO_APPROVE=100

# Session timeout (in minutes)
NEXT_PUBLIC_SESSION_TIMEOUT=30

# ============================================================================
# DEVELOPMENT
# ============================================================================

# Show console logs in browser
NEXT_PUBLIC_CONSOLE_LOGS=true

# Enable React Query DevTools
NEXT_PUBLIC_REACT_QUERY_DEVTOOLS=true
